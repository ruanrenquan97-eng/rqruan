{
    "version": 2,
    "installCommand": "pnpm install --no-frozen-lockfile",
    "buildCommand": "pnpm run build",
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server/_core/index.ts"
        }
    ]
}